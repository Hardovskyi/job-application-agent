# ── LLM provider ──────────────────────────────────────────────
# Which provider to use: "openai" | "anthropic" | "ollama"
LLM_PROVIDER=openai

# Model per provider (override the defaults if you like)
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
OLLAMA_MODEL=llama3.1

# API keys (only set the one matching LLM_PROVIDER)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Ollama needs no key; just run `ollama serve` locally.

# ── Web search tool ───────────────────────────────────────────
# Optional. If set, the company-research agent uses Tavily.
# If empty, it automatically falls back to DuckDuckGo (no key needed).
TAVILY_API_KEY=

# ── Observability (LangSmith tracing) ─────────────────────────
# Optional but recommended. Tracing turns ON automatically when this key is
# set; leave it empty to run without tracing (no warnings).
# Get a key at https://smith.langchain.com → Settings → API Keys.
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=job-application-agent

# ── Agent behavior ────────────────────────────────────────────
# Max self-correction loops before escalating to human review.
MAX_REVISIONS=2
